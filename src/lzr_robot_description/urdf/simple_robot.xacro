<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= 参数 ================= -->
  <xacro:property name="base_length" value="0.40"/>
  <xacro:property name="base_width"  value="0.30"/>
  <xacro:property name="base_height" value="0.10"/>

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width"  value="0.02"/>

  <!-- 万向轮比驱动轮略小，减少卡顿和摩擦拖拽 -->
  <xacro:property name="caster_radius" value="0.03"/>

  <xacro:property name="lidar_radius" value="0.05"/>
  <xacro:property name="lidar_height" value="0.05"/>

  <!-- 轮子中心高度：让底盘底面离地，不再蹭地 -->
  <!-- base底面 = wheel_center_z + base_height/2 -->
  <!-- 这里设为 -(wheel_radius + 0.01)，留一点离地间隙 -->
  <xacro:property name="wheel_z" value="-0.06"/>

  <!-- 轮子左右位置：略微外移，避免与底盘侧面干涉 -->
  <xacro:property name="wheel_y" value="0.16"/>

  <!-- 万向轮位置：后方，且高度与地面合理接触 -->
  <xacro:property name="caster_x" value="-0.16"/>
  <xacro:property name="caster_z" value="-0.08"/>

  <!-- ================= base_footprint ================= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + 0.01 - base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ================= 底盘 ================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia
        ixx="0.10" ixy="0.0" ixz="0.0"
        iyy="0.10" iyz="0.0"
        izz="0.10"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ================= 轮子宏 ================= -->
  <xacro:macro name="wheel" params="name y_pos">

    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia
          ixx="0.001" ixy="0.0" ixz="0.0"
          iyy="0.001" iyz="0.0"
          izz="0.001"/>
      </inertial>

      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <gazebo reference="${name}">
      <material>Gazebo/Black</material>
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>1.0</maxVel>
    </gazebo>

    <!-- 差速轮应连续转动 -->
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 ${y_pos} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- 左右驱动轮 -->
  <xacro:wheel name="wheel_left_link"  y_pos="${ wheel_y}"/>
  <xacro:wheel name="wheel_right_link" y_pos="${-wheel_y}"/>

  <!-- ================= 万向轮 ================= -->
  <link name="caster_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="0.0005" ixy="0.0" ixz="0.0"
        iyy="0.0005" iyz="0.0"
        izz="0.0005"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="caster_link">
    <material>Gazebo/Grey</material>
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${caster_x} 0 ${caster_z}" rpy="0 0 0"/>
  </joint>

  <!-- ================= 激光雷达 ================= -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="0.0005" ixy="0.0" ixz="0.0"
        iyy="0.0005" iyz="0.0"
        izz="0.0005"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${base_height/2 + lidar_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ================= Gazebo diff_drive 插件 ================= -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

      <leftJoint>wheel_left_link_joint</leftJoint>
      <rightJoint>wheel_right_link_joint</rightJoint>

      <wheelSeparation>0.32</wheelSeparation>
      <wheelDiameter>0.10</wheelDiameter>

      <robotBaseFrame>base_link</robotBaseFrame>

      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>

      <publishOdom>true</publishOdom>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelTF>false</publishWheelTF>

      <odometryFrame>odom</odometryFrame>

      <updateRate>50</updateRate>
      <wheelAcceleration>5.0</wheelAcceleration>
      <wheelTorque>20.0</wheelTorque>

      <legacyMode>false</legacyMode>
    </plugin>
  </gazebo>

</robot>
